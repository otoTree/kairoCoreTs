OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL_NAME=deepseek-chat
OPENAI_EMBEDDING_MODEL_NAME=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen3:0.6b
OLLAMA_EMBEDDING_MODEL_NAME=nomic-embed-text
KAIRO_TOKEN=
PORT=3000
PYTHON_ENV_PATH=../kairo_python_env
KAIRO_RUNTIME_DIR=.run/kairo
KAIRO_IPC_SOCKET=.run/kairo/kernel.sock
KAIRO_WS_TOKEN_FILE=.run/kairo/ws.token
SQLITE_DB_PATH=data/sqlite/kairo.db
KAIRO_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development
DEBUG=
KAIRO_MOCK_DEVICES=false
KAIRO_FEISHU_ENABLED=false
KAIRO_FEISHU_APP_ID=
KAIRO_FEISHU_APP_SECRET=
KAIRO_FEISHU_WEBHOOK_PATH=/api/channels/feishu/webhook
KAIRO_FEISHU_AGENT_ID=default
KAIRO_FEISHU_INBOX_DIR=workspace/feishu-inbox
KAIRO_FEISHU_MAX_UPLOAD_BYTES=31457280
KAIRO_FEISHU_VERIFICATION_TOKEN=
KAIRO_FEISHU_ENCRYPT_KEY=
